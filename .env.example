# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth - üret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# NEXTAUTH_URL is auto-detected in production; only set for local dev
# NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (tek kullanıcı)
ADMIN_EMAIL="mahmut@fizyoai.com"
ADMIN_PASSWORD="GüçlüŞifre123!"

# AI Providers
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# App config
NEXT_PUBLIC_APP_NAME="MY FizyoAI"
NEXT_PUBLIC_DEFAULT_PROVIDER="gemini"
NEXT_PUBLIC_DEFAULT_MODEL="gemini-2.5-flash"
MAX_FILE_SIZE_MB="10"
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,image/webp"
ENABLE_STREAMING="true"
ENABLE_AUTO_TITLE="true"
ENABLE_DISCLAIMER="true"

# Upload directory (Railway: volume mount path; local: default public/uploads)
# UPLOAD_DIR="/app/uploads"

# Upload directory (relative to project root)
UPLOAD_DIR="public/uploads"
